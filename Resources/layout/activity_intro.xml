<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0FF"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_dialog_map"
            android:background="#D8B4F8"
            android:padding="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POIMAP TOUR"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#6A0DAD"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khám phá ẩm thực và văn hóa Quận 4 theo cách hoàn toàn mới qua hệ thống Audio tự động."
            android:textSize="16sp"
            android:textColor="#555555"
            android:textAlignment="center"
            android:layout_marginTop="15dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnContinueToQr"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:text="TIẾP TỤC"
        android:backgroundTint="#8A2BE2"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"/>

</RelativeLayout>