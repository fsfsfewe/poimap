<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F0FF"
    android:padding="20dp">

	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

		<ImageButton
            android:id="@+id/btnBackToTours"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?android:attr/selectableItemBackground"
            android:tint="#6A0DAD"/>

		<TextView
            android:id="@+id/txtDetailTourName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên Tour"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#6A0DAD"
            android:layout_marginLeft="15dp"/>
	</LinearLayout>

	<TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DANH SÁCH ĐỊA ĐIỂM TRONG TOUR"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="10dp"/>

	<ListView
        android:id="@+id/listShopsInTour"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"
        android:background="#FFFFFF"
        android:elevation="2dp"/>

</LinearLayout>